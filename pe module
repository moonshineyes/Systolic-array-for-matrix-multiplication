module pe (
    input  wire        clk,
    input  wire        rst_n,   // 0 = reset
    input  wire        enable,  // 0 = PE is asleep (saves power)

    input  wire signed [7:0] a_in,   // from LEFT
    input  wire signed [7:0] b_in,   // from TOP

    output reg  signed [7:0] a_out,  // pass to RIGHT
    output reg  signed [7:0] b_out,  // pass to BOTTOM

    output reg  signed [31:0] acc    // accumulated result
);

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            // Reset: clear everything
            a_out <= 0;
            b_out <= 0;
            acc   <= 0;
        end
        else if (enable) begin
            // Pass data to neighbours
            a_out <= a_in;
            b_out <= b_in;
            // POWER SAVING: skip multiply if either input is zero
            // Uses OR-reduction (|) which is just ONE gate per input
            if (|a_in && |b_in)
                acc <= acc + (a_in * b_in);
        end
        // If enable=0: nothing changes, PE is frozen = zero dynamic power
    end

endmodule
